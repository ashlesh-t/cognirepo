{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "CogniRepo Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "CogniRepo observability dashboard — requests, latency, memory, graph, circuit breaker",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "HTTP",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "list"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(cognirepo_http_requests_total[5m])",
          "legendFormat": "{{route}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "options": {"legend": {"calcs": ["mean", "p95"], "displayMode": "list"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, rate(cognirepo_http_request_seconds_bucket[5m]))",
          "legendFormat": "p95 {{route}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, rate(cognirepo_http_request_seconds_bucket[5m]))",
          "legendFormat": "p50 {{route}}",
          "refId": "B"
        }
      ],
      "title": "Request Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 10,
      "title": "Memory & Graph",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"fixedColor": "blue", "mode": "fixed"}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 10},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "cognirepo_faiss_vectors",
          "legendFormat": "FAISS vectors",
          "refId": "A"
        }
      ],
      "title": "FAISS Vectors",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"fixedColor": "green", "mode": "fixed"}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 10},
      "id": 5,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "cognirepo_graph_nodes",
          "legendFormat": "graph nodes",
          "refId": "A"
        }
      ],
      "title": "Graph Nodes",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"fixedColor": "purple", "mode": "fixed"}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 10},
      "id": 6,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "cognirepo_graph_edges",
          "legendFormat": "graph edges",
          "refId": "A"
        }
      ],
      "title": "Graph Edges",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 2}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 10},
      "id": 7,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": true},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "cognirepo_circuit_breaker_state",
          "legendFormat": "CB state (0=CLOSED 1=HALF_OPEN 2=OPEN)",
          "refId": "A"
        }
      ],
      "title": "Circuit Breaker",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 11,
      "title": "Retrieval",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "id": 8,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, rate(cognirepo_retrieval_seconds_bucket[5m]))",
          "legendFormat": "p95 {{signal}}",
          "refId": "A"
        }
      ],
      "title": "Retrieval Latency p95 by Signal",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "ops", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "id": 9,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(cognirepo_memory_ops_total[5m])",
          "legendFormat": "{{op}} {{result}}",
          "refId": "A"
        }
      ],
      "title": "Memory Ops Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["cognirepo", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "CogniRepo",
  "uid": "cognirepo-main",
  "version": 1
}
