# ─── CogniRepo environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# .env is in .gitignore — never commit real keys.

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...           # also used for Cursor/Copilot/Codex endpoints
OPENAI_BASE_URL=                # leave blank for openai.com; set for Ollama / LM Studio

# ── Multi-Agent Collaboration (off by default) ────────────────────────────────
# When ON, a DEEP-tier query can spawn sub-queries via gRPC (rpc/server.py).
# Use case: Claude reasons → asks Gemini Flash for a fast symbol lookup → continues.
# Agent count: 1 orchestrator + up to N sub-agents (each a separate model call).
# Agent-to-agent interaction: orchestrator → gRPC → sub-agent (one level deep by default).
COGNIREPO_MULTI_AGENT_ENABLED=false
COGNIREPO_GRPC_HOST=localhost
COGNIREPO_GRPC_PORT=50051

# ── Circuit Breaker (OOM prevention) ─────────────────────────────────────────
# RSS limit in MB before the circuit opens and sheds load.
# Default: 80% of total system RAM (auto-detected).
COGNIREPO_CB_RSS_LIMIT_MB=
COGNIREPO_CB_COOLDOWN_SEC=30

# ── REST API ──────────────────────────────────────────────────────────────────
COGNIREPO_API_URL=http://localhost:8080
COGNIREPO_TOKEN=                # pre-set JWT token (skips password prompt in CLI)
COGNIREPO_PASSWORD=             # plain-text password for auto-login (dev only)

# ── gRPC Server ───────────────────────────────────────────────────────────────
COGNIREPO_GRPC_ENABLED=false    # start gRPC server alongside FastAPI
