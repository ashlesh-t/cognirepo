# ─── CogniRepo environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# All core features — indexing, memory, MCP tools, graph, summarize — work fully offline.
# API keys are reserved for future `cognirepo ask` (not yet available).
# .env is git-ignored — never commit real keys.

# ── LLM API Keys (reserved — future `cognirepo ask` command) ────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=                # leave blank for openai.com; set for Ollama / LM Studio
GROK_API_KEY=

# ── Circuit Breaker (OOM / storage protection) ────────────────────────────────
# RSS limit in MB before load-shedding kicks in. Defaults to 80% of system RAM.
COGNIREPO_CB_RSS_LIMIT_MB=2000
COGNIREPO_CB_COOLDOWN_SEC=30
COGNIREPO_CB_STORAGE_LIMIT_GIB=2.0
COGNIREPO_CB_MAX_CONCURRENT=2
COGNIREPO_CB_ACQUIRE_TIMEOUT_SEC=10
